<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LectureMobileApp.LectureDetailPage"
             Title="Деталі лекції">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="Назва лекції:" FontAttributes="Bold" />
            <Entry x:Name="TitleEntry" Placeholder="Введіть назву..." />

            <Label Text="Дисципліна:" FontAttributes="Bold" />
            <Entry x:Name="SubjectEntry" Placeholder="Наприклад: Основи веб-програмування" />

            <Label Text="Викладач:" FontAttributes="Bold" />
            <Entry x:Name="AuthorEntry" Placeholder="ПІБ автора" />

            <Label Text="Текст лекції:" FontAttributes="Bold" />
            <Editor x:Name="ContentEditor" 
                    Placeholder="Вставте вміст тут..." 
                    AutoSize="TextChanges" 
                    MinimumHeightRequest="200" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Зберегти" 
                        Clicked="OnSaveClicked" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White" 
                        WidthRequest="120" />

                <Button Text="Скасувати" 
                        Clicked="OnCancelClicked" 
                        BackgroundColor="Gray" 
                        TextColor="White" 
                        WidthRequest="120" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>