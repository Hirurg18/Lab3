<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LectureMobileApp.MainPage"
             Title="📚 Мої Лекції">

    <Grid RowDefinitions="*, Auto" Padding="10">

        <CollectionView x:Name="LecturesListView" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10" BorderColor="#E1E1E1">
                        <HorizontalStackLayout Spacing="10">
                            <VerticalStackLayout WidthRequest="200">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="{Binding AuthorName}" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding Subject}" FontSize="12" />
                            </VerticalStackLayout>

                            <Button Text="✏️" Clicked="OnEditClicked" CommandParameter="{Binding .}" Margin="2"/>
                            <Button Text="🗑️" Clicked="OnDeleteClicked" CommandParameter="{Binding .}" BackgroundColor="Red" Margin="2"/>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1" 
                Text="+ Додати нову лекцію" 
                Clicked="OnAddClicked" 
                Margin="0,10,0,0" 
                BackgroundColor="#2196F3" 
                TextColor="White" 
                FontAttributes="Bold" />
    </Grid>
</ContentPage>